# LKML Git Email Database — environment configuration
# Copy this file to .env and fill in your values, then: source .env

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Default (used if this variable is not set):
#   postgresql://mailinglist:yourpassword@127.0.0.1/mailinglist
LKML_DB_DSN=postgresql://mailinglist:yourpassword@127.0.0.1/mailinglist

# GitHub personal access token (optional but strongly recommended).
# Without this, the GitHub API is rate-limited to 60 requests/hour.
# With this, the limit is 5000/hour — needed to list all 219 repos.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=
